# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# private review submissions (written by /api/reviews)
data/review-submissions.json

# private blog drafts (written by /api/blog-drafts)
data/blog-drafts.json

# CMS admin credentials (created via /share/cms/setup)
data/cms-auth.json

# typescript
*.tsbuildinfo
next-env.d.ts
